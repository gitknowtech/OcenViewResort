<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>

<!-- Activities Section -->
<section class="section active">
    <div class="container">
        <h2 class="section-title">THINGS TO DO</h2>
        <div class="activities-grid">
            <div class="activity-detail">
                <i class="fas fa-water"></i>
                <h3>Water Sports</h3>
                <p>Experience thrilling water sports including kitesurfing, windsurfing, and jet skiing in the pristine waters of Kalpitiya.</p>
                <div class="activity-price">From $50/hour</div>
            </div>
            <div class="activity-detail">
                <i class="fas fa-fish"></i>
                <h3>Marine Life</h3>
                <p>Join our dolphin and whale watching tours to witness these magnificent creatures in their natural habitat.</p>
